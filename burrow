#!/bin/bash
# Burrow - Main CLI entrypoint.
# Routes subcommands and interactive menu.
# Handles update/remove flows.

set -euo pipefail

# Resolve config/lib directory: prefer ~/.config/burrow (manual install),
# fall back to script's own directory (Homebrew/dev layout).
SCRIPT_DIR="${BURROW_CONFIG_DIR:-$HOME/.config/burrow}"
if [[ ! -f "$SCRIPT_DIR/lib/core/common.sh" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

source "$SCRIPT_DIR/lib/core/common.sh"
source "$SCRIPT_DIR/lib/core/commands.sh"

trap cleanup_temp_files EXIT INT TERM

# Version and update helpers
VERSION="0.4.3"
BURROW_TAGLINE="macOS System Maintenance CLI"

# Migrate legacy Mole configuration on first run
_migrate_mole_config() {
    local old_config="$HOME/.config/mole"
    local new_config="$HOME/.config/burrow"
    local old_cache="$HOME/.cache/mole"
    local new_cache="$HOME/.cache/burrow"
    local old_agent="$HOME/Library/LaunchAgents/fun.tw93.mole.maintenance.plist"

    # Skip if already migrated or no old config exists
    [[ -d "$new_config" ]] && return 0
    [[ ! -d "$old_config" ]] && return 0

    echo -e "${BLUE}Migrating Mole configuration to Burrow...${NC}"

    # Copy config
    mkdir -p "$new_config"
    command cp -a "$old_config/." "$new_config/" 2> /dev/null || true

    # Copy cache
    if [[ -d "$old_cache" && ! -d "$new_cache" ]]; then
        mkdir -p "$new_cache"
        command cp -a "$old_cache/." "$new_cache/" 2> /dev/null || true
    fi

    # Unload old LaunchAgent
    if [[ -f "$old_agent" ]]; then
        launchctl bootout "gui/$(id -u)" "$old_agent" 2> /dev/null || true
    fi

    echo -e "  ${GREEN}${ICON_SUCCESS}${NC} Configuration migrated from ~/.config/mole to ~/.config/burrow"
}
_migrate_mole_config

is_touchid_configured() {
    local pam_sudo_file="/etc/pam.d/sudo"
    [[ -f "$pam_sudo_file" ]] && grep -q "pam_tid.so" "$pam_sudo_file" 2> /dev/null
}

get_latest_version() {
    curl -fsSL --connect-timeout 2 --max-time 3 -H "Cache-Control: no-cache" \
        "https://raw.githubusercontent.com/jimmy-jain/burrow/main/burrow" 2> /dev/null |
        grep '^VERSION=' | head -1 | sed 's/VERSION="\(.*\)"/\1/'
}

get_latest_version_from_github() {
    local version
    version=$(curl -fsSL --connect-timeout 2 --max-time 3 \
        "https://api.github.com/repos/jimmy-jain/burrow/releases/latest" 2> /dev/null |
        grep '"tag_name"' | head -1 | sed -E 's/.*"([^"]+)".*/\1/')
    version="${version#v}"
    version="${version#V}"
    echo "$version"
}

get_homebrew_latest_version() {
    command -v brew > /dev/null 2>&1 || return 1

    local line candidate=""

    # Prefer local tap outdated info to avoid notifying before formula is available.
    line=$(HOMEBREW_NO_AUTO_UPDATE=1 brew outdated --formula --verbose burrow 2> /dev/null | head -1 || true)
    if [[ "$line" == *"< "* ]]; then
        candidate="${line##*< }"
        candidate="${candidate%% *}"
    fi

    # Fallback for environments where outdated output is unavailable.
    if [[ -z "$candidate" ]]; then
        line=$(HOMEBREW_NO_AUTO_UPDATE=1 brew info burrow 2> /dev/null | awk 'NR==1 { print; exit }' || true)
        line="${line#==> }"
        line="${line#*: }"
        if [[ "$line" == stable* ]]; then
            candidate=$(printf '%s\n' "$line" | awk '{print $2}')
        fi
    fi

    [[ -n "$candidate" ]] && printf '%s\n' "$candidate"
}
# Install detection (Homebrew vs manual).
# Uses variable capture + string matching to avoid SIGPIPE under pipefail.
is_homebrew_install() {
    local burrow_path link_target has_brew=false
    burrow_path=$(command -v burrow 2> /dev/null) || return 1

    if command -v brew > /dev/null 2>&1; then
        has_brew=true
    fi

    if [[ -L "$burrow_path" ]]; then
        link_target=$(readlink "$burrow_path" 2> /dev/null) || true
        if [[ "$link_target" == *"Cellar/burrow"* ]]; then
            if $has_brew; then
                brew list burrow > /dev/null 2>&1 && return 0
            fi
            return 1
        fi
    fi

    if [[ -f "$burrow_path" ]]; then
        case "$burrow_path" in
            /opt/homebrew/bin/burrow | /usr/local/bin/burrow)
                if [[ -d /opt/homebrew/Cellar/burrow ]] || [[ -d /usr/local/Cellar/burrow ]]; then
                    if $has_brew; then
                        brew list burrow > /dev/null 2>&1 && return 0
                    else
                        return 0 # Cellar exists, probably Homebrew install
                    fi
                fi
                ;;
        esac
    fi

    if $has_brew; then
        local brew_prefix
        brew_prefix=$(brew --prefix 2> /dev/null)
        if [[ -n "$brew_prefix" && "$burrow_path" == "$brew_prefix/bin/burrow" && -d "$brew_prefix/Cellar/burrow" ]]; then
            brew list burrow > /dev/null 2>&1 && return 0
        fi
    fi

    return 1
}

get_install_channel() {
    # Try user config dir first (matches install.sh behavior), fallback to SCRIPT_DIR
    local channel_file="${BURROW_CONFIG_DIR:-$HOME/.config/burrow}/install_channel"
    if [[ ! -f "$channel_file" ]]; then
        channel_file="$SCRIPT_DIR/install_channel"
    fi
    local channel="stable"
    if [[ -f "$channel_file" ]]; then
        channel=$(sed -n 's/^CHANNEL=\(.*\)$/\1/p' "$channel_file" | head -1)
    fi
    case "$channel" in
        nightly | dev | stable) printf '%s\n' "$channel" ;;
        *) printf 'stable\n' ;;
    esac
}

get_install_commit() {
    # Try user config dir first (matches install.sh behavior), fallback to SCRIPT_DIR
    local channel_file="${BURROW_CONFIG_DIR:-$HOME/.config/burrow}/install_channel"
    if [[ ! -f "$channel_file" ]]; then
        channel_file="$SCRIPT_DIR/install_channel"
    fi
    if [[ -f "$channel_file" ]]; then
        sed -n 's/^COMMIT_HASH=\(.*\)$/\1/p' "$channel_file" | head -1
    fi
}

# Background update notice
check_for_updates() {
    local msg_cache="$HOME/.cache/burrow/update_message"
    ensure_user_dir "$(dirname "$msg_cache")"
    ensure_user_file "$msg_cache"

    # Skip if we checked within the last hour to reduce startup latency.
    # The background job runs GitHub API + brew calls that can take 3-9s.
    local check_ts_file="$HOME/.cache/burrow/version_check_time"
    if [[ -f "$check_ts_file" ]]; then
        local last_check
        last_check=$(cat "$check_ts_file" 2> /dev/null || echo "0")
        local now
        now=$(date +%s 2> /dev/null || echo "0")
        if [[ "$last_check" =~ ^[0-9]+$ && "$now" =~ ^[0-9]+$ && $((now - last_check)) -lt 3600 ]]; then
            return 0
        fi
    fi

    (
        (
            # Record check timestamp
            date +%s > "${check_ts_file}.tmp" 2> /dev/null && mv -f "${check_ts_file}.tmp" "$check_ts_file" 2> /dev/null || true
            local latest

            latest=$(get_latest_version_from_github)
            if [[ -z "$latest" ]]; then
                latest=$(get_latest_version)
            fi

            if [[ -n "$latest" && "$VERSION" != "$latest" && "$(printf '%s\n' "$VERSION" "$latest" | sort -V | head -1)" == "$VERSION" ]]; then
                if is_homebrew_install; then
                    # For Homebrew, only notify if the brew tap has the new version available locally
                    local brew_latest
                    brew_latest=$(get_homebrew_latest_version || true)
                    if [[ -n "$brew_latest" && "$brew_latest" != "$VERSION" && "$(printf '%s\n' "$VERSION" "$brew_latest" | sort -V | head -1)" == "$VERSION" ]]; then
                        printf "\nUpdate %s available, run %smo update%s\n\n" "$brew_latest" "$GREEN" "$NC" > "${msg_cache}.tmp" && mv -f "${msg_cache}.tmp" "$msg_cache"
                    else
                        echo -n > "${msg_cache}.tmp" && mv -f "${msg_cache}.tmp" "$msg_cache"
                    fi
                else
                    printf "\nUpdate %s available, run %smo update%s\n\n" "$latest" "$GREEN" "$NC" > "${msg_cache}.tmp" && mv -f "${msg_cache}.tmp" "$msg_cache"
                fi
            else
                echo -n > "${msg_cache}.tmp" && mv -f "${msg_cache}.tmp" "$msg_cache"
            fi
        ) > /dev/null 2>&1 < /dev/null &
    )
}

show_update_notification() {
    local msg_cache="$HOME/.cache/burrow/update_message"
    if [[ -f "$msg_cache" && -s "$msg_cache" ]]; then
        cat "$msg_cache"
        echo
    fi
}

# UI helpers
show_brand_banner() {
    cat << EOF
${GREEN} ____                                  ${NC}
${GREEN}| __ ) _   _ _ __ _ __ _____      __   ${NC}
${GREEN}|  _ \\| | | | '__| '__/ _ \\ \\ /\\ / /   ${NC}
${GREEN}| |_) | |_| | |  | | | (_) \\ V  V /    ${NC}  ${BLUE}https://github.com/jimmy-jain/burrow${NC}
${GREEN}|____/ \\__,_|_|  |_|  \\___/ \\_/\\_/     ${NC}  ${GREEN}${BURROW_TAGLINE}${NC}

EOF
}

show_version() {
    local os_ver
    if command -v sw_vers > /dev/null; then
        os_ver=$(sw_vers -productVersion)
    else
        os_ver="Unknown"
    fi

    local arch
    arch=$(uname -m)

    local kernel
    kernel=$(uname -r)

    local sip_status
    if command -v csrutil > /dev/null; then
        sip_status=$(csrutil status 2> /dev/null | grep -o "enabled\|disabled" || echo "Unknown")
        sip_status="$(LC_ALL=C tr '[:lower:]' '[:upper:]' <<< "${sip_status:0:1}")${sip_status:1}"
    else
        sip_status="Unknown"
    fi

    local disk_free
    disk_free=$(df -h / 2> /dev/null | awk 'NR==2 {print $4}' || echo "Unknown")

    local install_method="Manual"
    if is_homebrew_install; then
        install_method="Homebrew"
    fi

    local channel
    channel=$(get_install_channel)

    printf '\nBurrow version %s\n' "$VERSION"
    if [[ "$channel" == "nightly" ]]; then
        local commit
        commit=$(get_install_commit)
        if [[ -n "$commit" ]]; then
            printf 'Channel: Nightly (%s)\n' "$commit"
        else
            printf 'Channel: Nightly\n'
        fi
    fi
    printf 'macOS: %s\n' "$os_ver"
    printf 'Architecture: %s\n' "$arch"
    printf 'Kernel: %s\n' "$kernel"
    printf 'SIP: %s\n' "$sip_status"
    printf 'Disk Free: %s\n' "$disk_free"
    printf 'Install: %s\n' "$install_method"
    printf 'Shell: %s\n\n' "${SHELL:-Unknown}"
}

show_help() {
    show_brand_banner
    echo
    printf "%s%s%s\n" "$BLUE" "COMMANDS" "$NC"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw" "$NC" "Main menu"
    for entry in "${BURROW_COMMANDS[@]}"; do
        local name="${entry%%:*}"
        local desc="${entry#*:}"
        local display="bw $name"
        [[ "$name" == "help" ]] && display="bw --help"
        [[ "$name" == "version" ]] && display="bw --version"
        printf "  %s%-28s%s %s\n" "$GREEN" "$display" "$NC" "$desc"
    done
    echo
    printf "  %s%-28s%s %s\n" "$GREEN" "bw clean --dry-run" "$NC" "Preview cleanup"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw clean --whitelist" "$NC" "Manage protected caches"

    printf "  %s%-28s%s %s\n" "$GREEN" "bw optimize --dry-run" "$NC" "Preview optimization"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw optimize --whitelist" "$NC" "Manage protected items"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw uninstall --dry-run" "$NC" "Preview app uninstall"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw purge --dry-run" "$NC" "Preview project purge"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw installer --dry-run" "$NC" "Preview installer cleanup"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw touchid enable --dry-run" "$NC" "Preview Touch ID setup"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw completion --dry-run" "$NC" "Preview shell completion edits"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw log --since 7d" "$NC" "Show recent log entries"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw purge --paths" "$NC" "Configure scan directories"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw analyze /Volumes" "$NC" "Analyze external drives only"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw update --force" "$NC" "Force reinstall latest stable version"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw update --nightly" "$NC" "Install latest unreleased main branch build"
    printf "  %s%-28s%s %s\n" "$GREEN" "bw remove --dry-run" "$NC" "Preview Burrow removal"
    echo
    printf "%s%s%s\n" "$BLUE" "OPTIONS" "$NC"
    printf "  %s%-28s%s %s\n" "$GREEN" "--debug" "$NC" "Show detailed operation logs"
    echo
}

# Update flow (Homebrew or installer).
update_burrow() {
    local force_update="${1:-false}"
    local nightly_update="${2:-false}"
    local update_interrupted=false
    local sudo_keepalive_pid=""

    # Cleanup function for sudo keepalive
    _update_cleanup() {
        [[ -n "$sudo_keepalive_pid" ]] && _stop_sudo_keepalive "$sudo_keepalive_pid" || true
    }
    trap '_update_cleanup; update_interrupted=true; echo ""; exit 130' INT TERM

    if is_homebrew_install; then
        if [[ "$nightly_update" == "true" ]]; then
            log_error "Nightly update is only available for script installations"
            echo -e "${ICON_REVIEW} Homebrew installs follow stable releases."
            echo -e "${ICON_REVIEW} Reinstall via script to use: ${GRAY}bw update --nightly${NC}"
            exit 1
        fi
        update_via_homebrew "$VERSION"
        exit 0
    fi

    local latest=""
    local download_label="Downloading latest version..."
    local install_label="Installing update..."
    local final_success_label="latest version"

    if [[ "$nightly_update" == "true" ]]; then
        latest="main"
        download_label="Downloading nightly installer..."
        install_label="Installing nightly update..."
        final_success_label="nightly build (main)"
    else
        latest=$(get_latest_version_from_github)
        [[ -z "$latest" ]] && latest=$(get_latest_version)

        if [[ -z "$latest" ]]; then
            log_error "Unable to check for updates. Check network connection."
            echo -e "${ICON_REVIEW} Check if you can access GitHub, https://github.com"
            echo -e "${ICON_REVIEW} Try again with: ${GRAY}bw update${NC}"
            exit 1
        fi

        if [[ "$VERSION" == "$latest" && "$force_update" != "true" ]]; then
            echo ""
            echo -e "${GREEN}${ICON_SUCCESS}${NC} Already on latest version, ${VERSION}"
            echo ""
            exit 0
        fi
    fi

    if [[ -t 1 ]]; then
        start_inline_spinner "$download_label"
    else
        echo "${download_label%...}"
    fi

    local installer_url="https://raw.githubusercontent.com/jimmy-jain/burrow/main/install.sh"
    local tmp_installer
    tmp_installer="$(mktemp_file)" || {
        log_error "Update failed"
        exit 1
    }

    local download_error=""
    if command -v curl > /dev/null 2>&1; then
        download_error=$(curl -fsSL --connect-timeout 10 --max-time 60 "$installer_url" -o "$tmp_installer" 2>&1) || {
            local curl_exit=$?
            if [[ -t 1 ]]; then stop_inline_spinner; fi
            rm -f "$tmp_installer"
            log_error "Update failed, curl error: $curl_exit"

            case $curl_exit in
                6) echo -e "${ICON_REVIEW} Could not resolve host. Check DNS or network connection." ;;
                7) echo -e "${ICON_REVIEW} Failed to connect. Check network or proxy settings." ;;
                22) echo -e "${ICON_REVIEW} HTTP 404 Not Found. The installer may have moved." ;;
                28) echo -e "${ICON_REVIEW} Connection timed out. Try again or check firewall." ;;
                *) echo -e "${ICON_REVIEW} Check network connection and try again." ;;
            esac
            echo -e "${ICON_REVIEW} URL: $installer_url"
            exit 1
        }
    elif command -v wget > /dev/null 2>&1; then
        download_error=$(wget --timeout=10 --tries=3 -qO "$tmp_installer" "$installer_url" 2>&1) || {
            if [[ -t 1 ]]; then stop_inline_spinner; fi
            rm -f "$tmp_installer"
            log_error "Update failed, wget error"
            echo -e "${ICON_REVIEW} Check network connection and try again."
            echo -e "${ICON_REVIEW} URL: $installer_url"
            exit 1
        }
    else
        if [[ -t 1 ]]; then stop_inline_spinner; fi
        rm -f "$tmp_installer"
        log_error "curl or wget required"
        echo -e "${ICON_REVIEW} Install curl with: ${GRAY}brew install curl${NC}"
        exit 1
    fi

    if [[ -t 1 ]]; then stop_inline_spinner; fi
    chmod +x "$tmp_installer"

    local burrow_path
    burrow_path="$(command -v burrow 2> /dev/null || echo "$0")"
    local install_dir
    install_dir="$(cd "$(dirname "$burrow_path")" && pwd)"

    local requires_sudo="false"
    if [[ ! -w "$install_dir" ]]; then
        requires_sudo="true"
    elif [[ -e "$install_dir/burrow" && ! -w "$install_dir/burrow" ]]; then
        requires_sudo="true"
    fi

    if [[ "$requires_sudo" == "true" ]]; then
        if ! request_sudo_access "Burrow update requires admin access"; then
            log_error "Update aborted, admin access denied"
            rm -f "$tmp_installer"
            exit 1
        fi
        # Start sudo keepalive to prevent cache expiration during install
        sudo_keepalive_pid=$(_start_sudo_keepalive)
    fi

    if [[ -t 1 ]]; then
        start_inline_spinner "$install_label"
    else
        echo "${install_label%...}"
    fi

    process_install_output() {
        local output="$1"
        local fallback_version="$2"
        local success_label="$3"
        if [[ -t 1 ]]; then stop_inline_spinner; fi

        local filtered_output
        filtered_output=$(printf '%s\n' "$output" | sed '/^$/d')
        if [[ -n "$filtered_output" ]]; then
            printf '\n%s\n' "$filtered_output"
        fi

        if ! printf '%s\n' "$output" | grep -Eq "Updated to latest version|Already on latest version"; then
            local new_version
            new_version=$(printf '%s\n' "$output" | sed -n 's/.*-> \([^[:space:]]\{1,\}\).*/\1/p' | head -1)
            if [[ -z "$new_version" ]]; then
                new_version=$(printf '%s\n' "$output" | sed -n 's/.*version[[:space:]]\{1,\}\([^[:space:]]\{1,\}\).*/\1/p' | head -1)
            fi
            if [[ -z "$new_version" ]]; then
                new_version=$("$burrow_path" --version 2> /dev/null | awk 'NR==1 && NF {print $NF}' || echo "")
            fi
            if [[ -z "$new_version" ]]; then
                new_version="$fallback_version"
            fi
            printf '\n%s\n\n' "${GREEN}${ICON_SUCCESS}${NC} Updated to ${success_label}, ${new_version:-unknown}"
        else
            printf '\n'
        fi

        # Auto-update launcher scripts if installed
        if [[ -d "$HOME/Library/Application Support/Raycast/script-commands" ]] && \
           [[ -f "$SCRIPT_DIR/bin/launchers.sh" ]]; then
            source "$SCRIPT_DIR/bin/launchers.sh"
            if launcher_auto_update 2>/dev/null; then
                printf '%s\n' "  ${GREEN}${ICON_SUCCESS}${NC} Raycast launchers updated"
            fi
        fi
    }

    local install_output
    local update_tag="V${latest#V}"
    local config_dir="${BURROW_CONFIG_DIR:-$SCRIPT_DIR}"
    if [[ ! -f "$config_dir/lib/core/common.sh" ]]; then
        config_dir="$HOME/.config/burrow"
    fi

    if [[ "$nightly_update" == "true" ]]; then
        if install_output=$(BURROW_VERSION="main" "$tmp_installer" --prefix "$install_dir" --config "$config_dir" 2>&1); then
            process_install_output "$install_output" "$latest" "$final_success_label"
        else
            if [[ -t 1 ]]; then stop_inline_spinner; fi
            rm -f "$tmp_installer"
            _update_cleanup
            log_error "Nightly update failed"
            echo "$install_output" | tail -10 >&2 # Show last 10 lines of error
            exit 1
        fi
    elif [[ "$force_update" == "true" ]]; then
        if install_output=$(BURROW_VERSION="$update_tag" "$tmp_installer" --prefix "$install_dir" --config "$config_dir" 2>&1); then
            process_install_output "$install_output" "$latest" "$final_success_label"
        else
            if [[ -t 1 ]]; then stop_inline_spinner; fi
            rm -f "$tmp_installer"
            _update_cleanup
            log_error "Update failed"
            echo "$install_output" | tail -10 >&2 # Show last 10 lines of error
            exit 1
        fi
    else
        if install_output=$(BURROW_VERSION="$update_tag" "$tmp_installer" --prefix "$install_dir" --config "$config_dir" --update 2>&1); then
            process_install_output "$install_output" "$latest" "$final_success_label"
        else
            # Only retry without --update if the installer doesn't recognize the flag.
            # Retrying unconditionally masks legitimate errors (corrupt download,
            # missing permissions) and may install an unexpected version.
            if echo "$install_output" | grep -qi "unknown option\|Unknown option\|unrecognized option"; then
                if install_output=$(BURROW_VERSION="$update_tag" "$tmp_installer" --prefix "$install_dir" --config "$config_dir" 2>&1); then
                    process_install_output "$install_output" "$latest" "$final_success_label"
                else
                    if [[ -t 1 ]]; then stop_inline_spinner; fi
                    rm -f "$tmp_installer"
                    _update_cleanup
                    log_error "Update failed"
                    echo "$install_output" | tail -10 >&2
                    exit 1
                fi
            else
                if [[ -t 1 ]]; then stop_inline_spinner; fi
                rm -f "$tmp_installer"
                _update_cleanup
                log_error "Update failed"
                echo "$install_output" | tail -10 >&2
                exit 1
            fi
        fi
    fi

    rm -f "$tmp_installer"
    rm -f "$HOME/.cache/burrow/update_message"

    # Cleanup and reset trap
    _update_cleanup
    trap - INT TERM
}

# Remove flow (Homebrew + manual + config/cache).
remove_burrow() {
    local dry_run_mode="${1:-false}"
    local test_mode=false
    if [[ "${BURROW_TEST_MODE:-0}" == "1" ]]; then
        test_mode=true
    fi

    if [[ -t 1 ]]; then
        start_inline_spinner "Detecting Burrow installations..."
    else
        echo "Detecting installations..."
    fi

    local is_homebrew=false
    local brew_cmd=""
    local brew_has_burrow="false"
    local -a manual_installs=()
    local -a alias_installs=()

    if [[ "$test_mode" != "true" ]]; then
        if command -v brew > /dev/null 2>&1; then
            brew_cmd="brew"
        elif [[ -x "/opt/homebrew/bin/brew" ]]; then
            brew_cmd="/opt/homebrew/bin/brew"
        elif [[ -x "/usr/local/bin/brew" ]]; then
            brew_cmd="/usr/local/bin/brew"
        fi

        if [[ -n "$brew_cmd" ]]; then
            if "$brew_cmd" list burrow > /dev/null 2>&1; then
                brew_has_burrow="true"
            fi
        fi

        if [[ "$brew_has_burrow" == "true" ]] || is_homebrew_install; then
            is_homebrew=true
        fi
    fi

    local found_burrow
    found_burrow=""
    if [[ "$test_mode" != "true" ]]; then
        found_burrow=$(command -v burrow 2> /dev/null || true)
        if [[ -n "$found_burrow" && -f "$found_burrow" ]]; then
            if [[ ! -L "$found_burrow" ]] || ! readlink "$found_burrow" | grep -q "Cellar/burrow"; then
                manual_installs+=("$found_burrow")
            fi
        fi
    fi

    local -a fallback_paths=()
    if [[ "$test_mode" == "true" ]]; then
        fallback_paths=("$HOME/.local/bin/burrow")
    else
        fallback_paths=(
            "/usr/local/bin/burrow"
            "$HOME/.local/bin/burrow"
            "/opt/local/bin/burrow"
        )
    fi

    for path in "${fallback_paths[@]}"; do
        if [[ -f "$path" && "$path" != "$found_burrow" ]]; then
            if [[ ! -L "$path" ]] || ! readlink "$path" | grep -q "Cellar/burrow"; then
                manual_installs+=("$path")
            fi
        fi
    done

    local found_bw
    found_bw=""
    if [[ "$test_mode" != "true" ]]; then
        found_bw=$(command -v bw 2> /dev/null || true)
        if [[ -n "$found_bw" && -f "$found_bw" ]]; then
            if [[ ! -L "$found_bw" ]] || ! readlink "$found_bw" | grep -q "Cellar/burrow"; then
                alias_installs+=("$found_bw")
            fi
        fi
    fi

    local -a alias_fallback=()
    if [[ "$test_mode" == "true" ]]; then
        alias_fallback=("$HOME/.local/bin/bw")
    else
        alias_fallback=(
            "/usr/local/bin/bw"
            "$HOME/.local/bin/bw"
            "/opt/local/bin/bw"
        )
    fi

    for alias in "${alias_fallback[@]}"; do
        if [[ -f "$alias" && "$alias" != "$found_bw" ]]; then
            if [[ ! -L "$alias" ]] || ! readlink "$alias" | grep -q "Cellar/burrow"; then
                alias_installs+=("$alias")
            fi
        fi
    done

    if [[ -t 1 ]]; then
        stop_inline_spinner
    fi

    printf '\n'

    local manual_count=${#manual_installs[@]}
    local alias_count=${#alias_installs[@]}
    if [[ "$is_homebrew" == "false" && ${manual_count:-0} -eq 0 && ${alias_count:-0} -eq 0 ]]; then
        printf '%s\n\n' "${YELLOW}No Burrow installation detected${NC}"
        exit 0
    fi

    # Dry-run mode: show preview and exit without confirmation
    if [[ "$dry_run_mode" == "true" ]]; then
        echo -e "${YELLOW}${ICON_DRY_RUN} DRY RUN MODE${NC}, no files will be removed"
        echo ""
        echo -e "${YELLOW}Remove Burrow${NC}, would delete the following:"
        if [[ "$is_homebrew" == "true" ]]; then
            echo -e "  ${GRAY}${ICON_LIST} Would run: brew uninstall --force burrow${NC}"
        fi
        if [[ ${manual_count:-0} -gt 0 ]]; then
            for install in "${manual_installs[@]}"; do
                [[ -f "$install" ]] && echo -e "  ${GRAY}${ICON_LIST} Would remove: ${install}${NC}"
            done
        fi
        if [[ ${alias_count:-0} -gt 0 ]]; then
            for alias in "${alias_installs[@]}"; do
                [[ -f "$alias" ]] && echo -e "  ${GRAY}${ICON_LIST} Would remove: ${alias}${NC}"
            done
        fi
        [[ -d "$HOME/.cache/burrow" ]] && echo -e "  ${GRAY}${ICON_LIST} Would remove: $HOME/.cache/burrow${NC}"
        [[ -d "$HOME/.config/burrow" ]] && echo -e "  ${GRAY}${ICON_LIST} Would remove: $HOME/.config/burrow${NC}"

        printf '\n%s\n\n' "${GREEN}${ICON_SUCCESS}${NC} Dry run complete, no changes made"
        exit 0
    fi

    echo -e "${YELLOW}Remove Burrow${NC}, will delete the following:"
    if [[ "$is_homebrew" == "true" ]]; then
        echo "  ${ICON_LIST} Burrow via Homebrew"
    fi
    for install in ${manual_installs[@]+"${manual_installs[@]}"} ${alias_installs[@]+"${alias_installs[@]}"}; do
        echo "  ${ICON_LIST} $install"
    done
    [[ -d "$HOME/.config/burrow" ]] && echo "  ${ICON_LIST} ~/.config/burrow"
    [[ -d "$HOME/.cache/burrow" ]] && echo "  ${ICON_LIST} ~/.cache/burrow"
    echo -ne "${PURPLE}${ICON_ARROW}${NC} Press ${GREEN}Enter${NC} to confirm, ${GRAY}ESC${NC} to cancel: "

    IFS= read -r -s -n1 key || key=""
    drain_pending_input # Clean up any escape sequence remnants
    case "$key" in
        $'\e')
            exit 0
            ;;
        "" | $'\n' | $'\r')
            printf "\r\033[K" # Clear the prompt line
            ;;
        *)
            exit 0
            ;;
    esac

    local has_error=false
    if [[ "$is_homebrew" == "true" ]]; then
        if [[ -z "$brew_cmd" ]]; then
            log_error "Homebrew command not found. Please ensure Homebrew is installed and in your PATH."
            log_warning "Manual step: brew uninstall --force burrow"
            exit 1
        fi

        log_info "Attempting to uninstall Burrow via Homebrew..."
        local brew_uninstall_output
        if ! brew_uninstall_output=$("$brew_cmd" uninstall --force burrow 2>&1); then
            has_error=true
            log_error "Homebrew uninstallation failed:"
            printf "%s\n" "$brew_uninstall_output" | sed "s/^/${RED}  | ${NC}/" >&2
            log_warning "Manual step: ${YELLOW}brew uninstall --force burrow${NC}"
            echo "" # Add a blank line for readability
        else
            log_success "Burrow uninstalled via Homebrew."
        fi
    fi
    if [[ ${manual_count:-0} -gt 0 ]]; then
        for install in "${manual_installs[@]}"; do
            if [[ -f "$install" ]]; then
                if [[ ! -w "$(dirname "$install")" ]]; then
                    if ! sudo rm -f "$install" 2> /dev/null; then
                        has_error=true
                    fi
                else
                    if ! rm -f "$install" 2> /dev/null; then
                        has_error=true
                    fi
                fi
            fi
        done
    fi
    if [[ ${alias_count:-0} -gt 0 ]]; then
        for alias in "${alias_installs[@]}"; do
            if [[ -f "$alias" ]]; then
                if [[ ! -w "$(dirname "$alias")" ]]; then
                    if ! sudo rm -f "$alias" 2> /dev/null; then
                        has_error=true
                    fi
                else
                    if ! rm -f "$alias" 2> /dev/null; then
                        has_error=true
                    fi
                fi
            fi
        done
    fi
    if [[ -d "$HOME/.cache/burrow" ]]; then
        rm -rf "$HOME/.cache/burrow" 2> /dev/null || true
    fi
    if [[ -d "$HOME/.config/burrow" ]]; then
        rm -rf "$HOME/.config/burrow" 2> /dev/null || true
    fi

    local final_message
    if [[ "$has_error" == "true" ]]; then
        final_message="${YELLOW}${ICON_ERROR} Burrow uninstalled with some errors, thank you for using Burrow!${NC}"
    else
        final_message="${GREEN}${ICON_SUCCESS} Burrow uninstalled successfully, thank you for using Burrow!${NC}"
    fi
    printf '\n%s\n\n' "$final_message"

    exit 0
}

# Menu UI
show_main_menu() {
    local selected="${1:-1}"
    local banner="${MAIN_MENU_BANNER:-}"
    local update_message="${MAIN_MENU_UPDATE_MESSAGE:-}"

    if [[ -z "$banner" ]]; then
        banner="$(show_brand_banner)"
        MAIN_MENU_BANNER="$banner"
    fi

    printf '\033[H'

    local line=""
    printf '\r\033[2K\n'

    while IFS= read -r line || [[ -n "$line" ]]; do
        printf '\r\033[2K%s\n' "$line"
    done <<< "$banner"

    if [[ -n "$update_message" ]]; then
        while IFS= read -r line || [[ -n "$line" ]]; do
            printf '\r\033[2K%s\n' "$line"
        done <<< "$update_message"
    fi

    printf '\r\033[2K\n'

    printf '\r\033[2K%s\n' "$(show_menu_option 1 "Clean        Free up disk space" "$([[ $selected -eq 1 ]] && echo true || echo false)")"
    printf '\r\033[2K%s\n' "$(show_menu_option 2 "Uninstall    Remove apps completely" "$([[ $selected -eq 2 ]] && echo true || echo false)")"
    printf '\r\033[2K%s\n' "$(show_menu_option 3 "Optimize     Check and maintain system" "$([[ $selected -eq 3 ]] && echo true || echo false)")"
    printf '\r\033[2K%s\n' "$(show_menu_option 4 "Analyze      Explore disk usage" "$([[ $selected -eq 4 ]] && echo true || echo false)")"
    printf '\r\033[2K%s\n' "$(show_menu_option 5 "Status       Monitor system health" "$([[ $selected -eq 5 ]] && echo true || echo false)")"

    if [[ -t 0 ]]; then
        printf '\r\033[2K\n'
        local controls="${GRAY}↑↓  |  Enter  |  M More  |  V Version"
        if ! is_touchid_configured; then
            controls="${controls}  |  T TouchID"
        elif [[ "${MAIN_MENU_SHOW_UPDATE:-false}" == "true" ]]; then
            controls="${controls}  |  U Update"
        fi
        controls="${controls}  |  Q Quit${NC}"
        printf '\r\033[2K%s\n' "$controls"
        printf '\r\033[2K\n'
    fi

    printf '\033[J'
}

interactive_main_menu() {
    local current_option=1
    local brand_banner=""
    local msg_cache="$HOME/.cache/burrow/update_message"
    local update_message=""

    brand_banner="$(show_brand_banner)"
    MAIN_MENU_BANNER="$brand_banner"

    if [[ -f "$msg_cache" && -s "$msg_cache" ]]; then
        update_message="$(cat "$msg_cache" 2> /dev/null || echo "")"
    fi
    MAIN_MENU_UPDATE_MESSAGE="$update_message"
    MAIN_MENU_SHOW_UPDATE="$([[ -n "$update_message" ]] && echo true || echo false)"

    cleanup_and_exit() {
        show_cursor
        exit 0
    }

    trap cleanup_and_exit INT
    hide_cursor

    while true; do
        show_main_menu $current_option

        local key
        if ! key=$(read_key); then
            continue
        fi

        case "$key" in
            "UP") ((current_option > 1)) && ((current_option--)) ;;
            "DOWN") ((current_option < 5)) && ((current_option++)) ;;
            "ENTER")
                show_cursor
                case $current_option in
                    1) exec "$SCRIPT_DIR/bin/clean.sh" ;;
                    2) exec "$SCRIPT_DIR/bin/uninstall.sh" ;;
                    3) exec "$SCRIPT_DIR/bin/optimize.sh" ;;
                    4) exec "$SCRIPT_DIR/bin/analyze.sh" ;;
                    5) exec "$SCRIPT_DIR/bin/status.sh" ;;
                esac
                ;;
            "CHAR:1")
                show_cursor
                exec "$SCRIPT_DIR/bin/clean.sh"
                ;;
            "CHAR:2")
                show_cursor
                exec "$SCRIPT_DIR/bin/uninstall.sh"
                ;;
            "CHAR:3")
                show_cursor
                exec "$SCRIPT_DIR/bin/optimize.sh"
                ;;
            "CHAR:4")
                show_cursor
                exec "$SCRIPT_DIR/bin/analyze.sh"
                ;;
            "CHAR:5")
                show_cursor
                exec "$SCRIPT_DIR/bin/status.sh"
                ;;
            "MORE")
                show_cursor
                clear
                show_help
                exit 0
                ;;
            "VERSION")
                show_cursor
                clear
                show_version
                exit 0
                ;;
            "TOUCHID")
                show_cursor
                exec "$SCRIPT_DIR/bin/touchid.sh"
                ;;
            "UPDATE")
                if [[ "${MAIN_MENU_SHOW_UPDATE:-false}" != "true" ]]; then
                    # Briefly show feedback when user presses U but no update is available
                    printf '\r\033[2K  %s' "Already on latest version"
                    sleep 1
                    continue
                fi
                show_cursor
                clear
                update_burrow
                exit 0
                ;;
            "QUIT") cleanup_and_exit ;;
        esac

        drain_pending_input
    done
}

# CLI dispatch
main() {
    local -a args=()
    for arg in "$@"; do
        case "$arg" in
            --debug)
                export BW_DEBUG=1
                ;;
            *)
                args+=("$arg")
                ;;
        esac
    done

    case "${args[0]:-""}" in
        "optimize")
            exec "$SCRIPT_DIR/bin/optimize.sh" "${args[@]:1}"
            ;;
        "clean")
            exec "$SCRIPT_DIR/bin/clean.sh" "${args[@]:1}"
            ;;
        "uninstall")
            exec "$SCRIPT_DIR/bin/uninstall.sh" "${args[@]:1}"
            ;;
        "analyze")
            exec "$SCRIPT_DIR/bin/analyze.sh" "${args[@]:1}"
            ;;
        "status")
            exec "$SCRIPT_DIR/bin/status.sh" "${args[@]:1}"
            ;;
        "purge")
            exec "$SCRIPT_DIR/bin/purge.sh" "${args[@]:1}"
            ;;
        "installer")
            exec "$SCRIPT_DIR/bin/installer.sh" "${args[@]:1}"
            ;;
        "touchid")
            exec "$SCRIPT_DIR/bin/touchid.sh" "${args[@]:1}"
            ;;
        "completion")
            exec "$SCRIPT_DIR/bin/completion.sh" "${args[@]:1}"
            ;;
        "size")
            exec "$SCRIPT_DIR/bin/size.sh" "${args[@]:1}"
            ;;
        "doctor")
            exec "$SCRIPT_DIR/bin/doctor.sh" "${args[@]:1}"
            ;;
        "log")
            exec "$SCRIPT_DIR/bin/log.sh" "${args[@]:1}"
            ;;
        "report")
            exec "$SCRIPT_DIR/bin/report.sh" "${args[@]:1}"
            ;;
        "dupes")
            exec "$SCRIPT_DIR/bin/dupes.sh" "${args[@]:1}"
            ;;
        "watch")
            exec "$SCRIPT_DIR/bin/watch.sh" "${args[@]:1}"
            ;;
        "schedule")
            exec "$SCRIPT_DIR/bin/schedule.sh" "${args[@]:1}"
            ;;
        "hook")
            exec "$SCRIPT_DIR/bin/hook.sh" "${args[@]:1}"
            ;;
        "launchers")
            exec "$SCRIPT_DIR/bin/launchers.sh" "${args[@]:1}"
            ;;
        "update")
            local force_update=false
            local nightly_update=false
            for arg in "${args[@]:1}"; do
                case "$arg" in
                    --force | -f) force_update=true ;;
                    --nightly) nightly_update=true ;;
                    *)
                        echo "Unknown update option: $arg"
                        echo "Use 'burrow update [--force] [--nightly]' for supported options."
                        exit 1
                        ;;
                esac
            done
            update_burrow "$force_update" "$nightly_update"
            exit 0
            ;;
        "remove")
            local dry_run_remove=false
            for arg in "${args[@]:1}"; do
                case "$arg" in
                    "--dry-run" | "-n") dry_run_remove=true ;;
                    *)
                        echo "Unknown remove option: $arg"
                        echo "Use 'burrow remove [--dry-run]' for supported options."
                        exit 1
                        ;;
                esac
            done
            remove_burrow "$dry_run_remove"
            ;;
        "help" | "--help" | "-h")
            show_help
            exit 0
            ;;
        "version" | "--version" | "-V")
            show_version
            exit 0
            ;;
        "")
            check_for_updates
            interactive_main_menu
            ;;
        *)
            echo "Unknown command: ${args[0]}"
            echo "Use 'burrow --help' for usage information."
            exit 1
            ;;
    esac
}

if [[ "${BURROW_TEST_MODE:-0}" == "1" && "${BURROW_SKIP_MAIN:-0}" == "1" ]]; then
    :
else
    main "$@"
fi
